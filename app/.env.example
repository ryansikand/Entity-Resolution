# UiPath OAuth Configuration
# Get these values from your UiPath Cloud Admin Tab

VITE_UIPATH_CLIENT_ID=your-oauth-client-id
VITE_UIPATH_ORG_NAME=your-organization-name
VITE_UIPATH_TENANT_NAME=your-tenant-name
VITE_UIPATH_BASE_URL=https://api.uipath.com
VITE_UIPATH_REDIRECT_URI=http://localhost:5173 # url where app is running
VITE_UIPATH_SCOPE=OR.Administration OR.Execution.Read OR.Jobs OR.Jobs.Read OR.Jobs.Write OR.Tasks OR.Tasks.Read OR.Tasks.Write PIMS DataFabric.Schema.Read DataFabric.Data.Read DataFabric.Data.Write

# Entity ID for attachments and data retrieval
# Replace with your specific entity ID from Data Service to fetch any relevant data
VITE_UIPATH_ENTITY_ID=your-entity-id-here

# Maestro Process Key
# Replace with your Maestro process definition key for deep linking to process instances
VITE_MAESTRO_PROCESS_KEY=your-maestro-process-key
VITE_MAESTRO_FOLDER_KEY=your-maestro-folder-key-guid
# Numeric Orchestrator folder id used by Processes.start()
VITE_MAESTRO_FOLDER_ID=your-orchestrator-folder-id
VITE_MAESTRO_RUNTIME_TYPE=Unattended
VITE_MAESTRO_JOBS_COUNT=1
# Set to true only for personal remote automation / run-as-current-user starts
VITE_MAESTRO_RUN_AS_ME=false

# Debug Settings
# Set to 'true' to show debug box with raw process variables in investigation details
VITE_SHOW_DEBUG_BOX=false
